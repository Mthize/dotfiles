return {
	"hrsh7th/nvim-cmp",
	event = "InsertEnter",
	dependencies = {
		"hrsh7th/cmp-buffer",
		"hrsh7th/cmp-path",
		"supermaven-inc/supermaven-nvim",
		{
			"L3MON4D3/LuaSnip",
			version = "v2.*",
			build = "make install_jsregexp",
		},
		"saadparwaiz1/cmp_luasnip",
		"rafamadriz/friendly-snippets",
		"onsails/lspkind.nvim",
	},
	config = function()
		local cmp = require("cmp")
		local luasnip = require("luasnip")
		local lspkind = require("lspkind")
		local suggestion = require("supermaven-nvim.completion_preview")

		-- Catppuccin Mocha-compatible Supermaven setup
		require("supermaven-nvim").setup({
			keymaps = {
				accept_suggestion = "<M-l>", -- Alt+l for full suggestion
				accept_word = "<M-j>", -- Alt+j for single word
				clear_suggestion = "<M-k>", -- Alt+k to clear
			},
			ignore_filetypes = { "cpp", "markdown", "text" },
			color = {
				suggestion_color = "#a6e3a1", -- Catppuccin green (perfect for Mocha)
				cterm = 108, -- Terminal-compatible green
			},
			disable_keymaps = true, -- We'll handle keymaps in cmp
			max_suggestion_width = 80,
		})

		-- Load snippets
		require("luasnip.loaders.from_vscode").lazy_load()

		cmp.setup({
			completion = {
				completeopt = "menu,menuone,preview,noselect",
				autocomplete = {
					cmp.TriggerEvent.TextChanged,
					cmp.TriggerEvent.InsertEnter,
				},
			},
			snippet = {
				expand = function(args)
					luasnip.lsp_expand(args.body)
				end,
			},
			mapping = cmp.mapping.preset.insert({
				-- Enhanced Tab behavior with Catppuccin-friendly flow:
				["<Tab>"] = cmp.mapping(function(fallback)
					if cmp.visible() then
						cmp.select_next_item()
					elseif luasnip.expand_or_jumpable() then
						luasnip.expand_or_jump()
					elseif suggestion.has_suggestion() then
						suggestion.on_accept_suggestion()
					else
						fallback()
					end
				end, { "i", "s" }),

				["<S-Tab>"] = cmp.mapping(function(fallback)
					if cmp.visible() then
						cmp.select_prev_item()
					elseif luasnip.jumpable(-1) then
						luasnip.jump(-1)
					else
						fallback()
					end
				end, { "i", "s" }),

				-- Supermaven keys with Catppuccin color feedback
				["<M-l>"] = cmp.mapping(function()
					if suggestion.has_suggestion() then
						vim.cmd("hi SupermavenAccept guifg=#a6e3a1") -- Flash green on accept
						suggestion.on_accept_suggestion()
						vim.defer_fn(function()
							vim.cmd("hi SupermavenAccept guifg=NONE")
						end, 200)
					else
						cmp.confirm({ select = true })
					end
				end),

				["<M-j>"] = cmp.mapping(function()
					if suggestion.has_suggestion() then
						vim.cmd("hi SupermavenAccept guifg=#94e2d5") -- Teal for partial accept
						suggestion.on_accept_word()
						vim.defer_fn(function()
							vim.cmd("hi SupermavenAccept guifg=NONE")
						end, 150)
					else
						cmp.select_next_item()
					end
				end),

				["<M-k>"] = cmp.mapping(function()
					suggestion.clear_suggestion()
					vim.cmd("hi SupermavenClear guifg=#f38ba8") -- Red flash on clear
					vim.defer_fn(function()
						vim.cmd("hi SupermavenClear guifg=NONE")
					end, 150)
				end),

				-- Preserved keybinds
				["<C-k>"] = cmp.mapping.select_prev_item(),
				["<C-b>"] = cmp.mapping.scroll_docs(-4),
				["<C-f>"] = cmp.mapping.scroll_docs(4),
				["<C-Space>"] = cmp.mapping.complete(),
				["<C-e>"] = cmp.mapping.abort(),
				["<CR>"] = cmp.mapping.confirm({
					select = false,
					behavior = cmp.ConfirmBehavior.Replace,
				}),
			}),
			sources = cmp.config.sources({
				{ name = "supermaven", priority = 1000 },
				{ name = "nvim_lsp", priority = 900 },
				{ name = "luasnip", priority = 800 },
				{ name = "buffer", priority = 700 },
				{ name = "path", priority = 600 },
			}),
			formatting = {
				format = lspkind.cmp_format({
					mode = "symbol_text",
					maxwidth = 50,
					ellipsis_char = "...",
					symbol_map = { Supermaven = "ż " }, -- Catppuccin-style icon
					menu = {
						supermaven = " ż AI ",
						nvim_lsp = " ż LSP ",
						luasnip = " ż Snippet ",
						buffer = " ż Buffer ",
						path = " ż Path ",
					},
					preset = "codicons",
				}),
			},
			window = {
				completion = {
					winhighlight = "Normal:Pmenu,FloatBorder:PmenuBorder,CursorLine:PmenuSel,Search:None",
					col_offset = -1,
					side_padding = 0,
				},
				documentation = {
					border = "rounded",
					winhighlight = "Normal:NormalFloat,FloatBorder:FloatBorder",
				},
			},
			experimental = {
				ghost_text = {
					hl_group = "Comment",
				},
			},
		})

		-- Apply Catppuccin Mocha-specific highlights
		vim.api.nvim_set_hl(0, "SupermavenSuggestion", { fg = "#a6e3a1", italic = true })
		vim.api.nvim_set_hl(0, "PmenuSel", { bg = "#585b70" }) -- Mocha surface1

		-- Smart Supermaven management for Catppuccin
		local api = require("supermaven-nvim.api")
		vim.api.nvim_create_autocmd({ "BufEnter", "FileType" }, {
			pattern = "*",
			callback = function()
				local ft = vim.bo.filetype
				if vim.tbl_contains({ "cpp", "markdown", "text" }, ft) then
					if api.is_running() then
						api.stop()
					end
				elseif not api.is_running() then
					api.start()
				end
			end,
		})

		-- Toggle command with Catppuccin colors
		vim.api.nvim_create_user_command("SupermavenToggle", function()
			if api.is_running() then
				api.stop()
				vim.notify("Supermaven ż ż Disabled", vim.log.levels.WARN, { title = "AI Completion" })
			else
				api.start()
				vim.notify("Supermaven ż ż Enabled", vim.log.levels.INFO, { title = "AI Completion" })
			end
		end, {})
	end,
}z
