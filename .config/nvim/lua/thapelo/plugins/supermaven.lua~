return {
	"supermaven-inc/supermaven-nvim",
	event = "InsertEnter",
	dependencies = {
		"hrsh7th/nvim-cmp",
		"L3MON4D3/LuaSnip",
		"onsails/lspkind.nvim", -- Better icon support
	},
	config = function()
		local supermaven = require("supermaven-nvim")
		local api = require("supermaven-nvim.api")
		local suggestion = require("supermaven-nvim.completion_preview")

		-- Customizable settings (modify these to your preference)
		local config = {
			keymaps = {
				accept_suggestion = "<M-l>", -- Alt+l to accept full suggestion
				accept_alternative = "<M-k>", -- Alt+k for alternative suggestion
				accept_word = "<M-j>", -- Alt+j to accept word
				clear_suggestion = "<C-]>", -- Keep default clear
				show_suggestions = "<M-h>", -- Alt+h to show suggestions
			},
			ignore_filetypes = { "cpp", "txt" },
			color = {
				suggestion_color = "#FFA500", -- More visible orange color
				cterm = 214, -- Brighter orange in terminals
			},
			log_level = "warn", -- Reduce log noise
			disable_inline_completion = false,
			disable_keymaps = false,
			max_suggestion_width = 80, -- Prevent too-wide suggestions
			max_suggestion_height = 5, -- Limit suggestion height
		}

		supermaven.setup(config)

		-- Smart startup with filetype check
		vim.api.nvim_create_autocmd("FileType", {
			pattern = "*",
			callback = function()
				if not vim.tbl_contains(config.ignore_filetypes, vim.bo.filetype) then
					if not api.is_running() then
						api.start()
					end
				end
			end,
		})

		-- Enhanced cmp integration
		if pcall(require, "cmp") then
			local cmp = require("cmp")
			local luasnip = require("luasnip")

			cmp.setup({
				snippet = {
					expand = function(args)
						luasnip.lsp_expand(args.body)
					end,
				},
				mapping = cmp.mapping.preset.insert({
					-- Supermaven suggestions
					[config.keymaps.accept_suggestion] = function()
						if suggestion.has_suggestion() then
							suggestion.on_accept_suggestion()
						end
					end,
					[config.keymaps.accept_word] = function()
						if suggestion.has_suggestion() then
							suggestion.on_accept_word()
						end
					end,
					[config.keymaps.clear_suggestion] = function()
						if suggestion.has_suggestion() then
							suggestion.clear_suggestion()
						end
					end,

					-- Tab completion enhancements
					["<Tab>"] = cmp.mapping(function(fallback)
						if cmp.visible() then
							cmp.select_next_item()
						elseif luasnip.expand_or_jumpable() then
							luasnip.expand_or_jump()
						elseif suggestion.has_suggestion() then
							suggestion.on_accept_suggestion()
						else
							fallback()
						end
					end, { "i", "s" }),

					["<S-Tab>"] = cmp.mapping(function(fallback)
						if cmp.visible() then
							cmp.select_prev_item()
						elseif luasnip.jumpable(-1) then
							luasnip.jump(-1)
						else
							fallback()
						end
					end, { "i", "s" }),
				}),

				sources = cmp.config.sources({
					{ name = "supermaven", priority = 1000 }, -- Highest priority
					{ name = "nvim_lsp", priority = 900 },
					{ name = "luasnip", priority = 800 },
					{ name = "buffer", priority = 700 },
					{ name = "path", priority = 600 },
				}),

				formatting = {
					format = require("lspkind").cmp_format({
						mode = "symbol_text",
						maxwidth = 50,
						ellipsis_char = "...",
						symbol_map = { Supermaven = "ż " }, -- Custom icon
					}),
				},
			})
		end

		-- Toggle commands
		vim.api.nvim_create_user_command("SupermavenToggle", function()
			if api.is_running() then
				api.stop()
				print("Supermaven disabled")
			else
				api.start()
				print("Supermaven enabled")
			end
		end, {})

		vim.api.nvim_create_user_command("SupermavenClear", function()
			suggestion.clear_suggestion()
		end, {})
	end,
}
